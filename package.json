{
    "name": "@kdtlabs/utils",
    "type": "module",
    "version": "0.0.14",
    "description": "A comprehensive TypeScript utility library",
    "author": "Diep Dang <kdt310722@gmail.com>",
    "license": "MIT",
    "homepage": "https://github.com/kdtlabs/utils",
    "repository": "github:kdtlabs/utils",
    "bugs": {
        "url": "https://github.com/kdtlabs/utils/issues",
        "email": "kdt310722@gmail.com"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./zod": {
            "types": "./dist/zod/index.d.ts",
            "default": "./dist/zod/index.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "SKILL.md",
        "dist",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rimraf dist && bun run scripts/build.ts && tsc --project tsconfig.build.json",
        "release": "bun run build && bun run scripts/release.ts && bunx npm publish",
        "coverage": "bun test --coverage",
        "lint": "eslint",
        "lint:fix": "bun run lint --fix",
        "typecheck": "tsc --noEmit",
        "up": "taze -I --group --force --peer",
        "preinstall": "only-allow bun && ([ -d .git ] && simple-git-hooks || true)"
    },
    "peerDependencies": {
        "zod": "^4.3.6"
    },
    "peerDependenciesMeta": {
        "zod": {
            "optional": true
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@kdtlabs/eslint-config": "^0.0.6",
        "@types/bun": "^1.3.12",
        "@types/node": "^25.6.0",
        "changelogen": "^0.6.2",
        "eslint": "^10.2.0",
        "lint-staged": "^16.4.0",
        "mitata": "^1.0.34",
        "only-allow": "^1.2.2",
        "rimraf": "^6.1.3",
        "simple-git-hooks": "^2.13.1",
        "taze": "^19.11.0",
        "typescript": "^6.0.3",
        "zod": "^4.3.6"
    },
    "simple-git-hooks": {
        "commit-msg": "bunx --no -- commitlint --edit ${1}",
        "pre-commit": "bunx lint-staged && bun run typecheck"
    },
    "lint-staged": {
        "*": "bun run lint:fix"
    },
    "commitlint": {
        "extends": "@commitlint/config-conventional"
    }
}
